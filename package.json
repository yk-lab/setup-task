{
  "name": "setup-task",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action to install the Task (go-task) binary — Node 24, authenticated, checksum-verified, cached.",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "all": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/tool-cache": "^4.0.0",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.5",
    "@types/semver": "^7.5.8",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^10.5.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.9"
  }
}
